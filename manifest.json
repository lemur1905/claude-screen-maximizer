{
  "manifest_version": 3,
  "name": "Screen Maximizer for Claude",
  "version": "1.2.0",
  "description": "Hide the prompt box, sidebar, and menus on claude.ai with keyboard shortcuts. Unofficial; not affiliated with Anthropic.",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Screen Maximizer for Claude",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
