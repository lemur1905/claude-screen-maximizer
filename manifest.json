{
  "manifest_version": 3,
  "name": "Claude Screen Maximizer",
  "version": "1.1.0",
  "description": "Keyboard shortcuts to hide UI elements on Claude.ai for maximum screen real estate",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Claude Screen Maximizer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
